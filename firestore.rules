rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    function hasAnyRole(roles) {
      return isAuthenticated() && getUserData().role in roles;
    }

    // Users collection - owner-scoped access with role protection
    match /users/{userId} {
      // Users can only read their own profile, admins can read all
      allow read: if isOwner(userId) || hasRole('admin');
      
      // Create only if authenticated and creating own profile
      // Prevent self-assignment of admin role
      allow create: if isOwner(userId) && 
                       request.resource.data.role != 'admin';
      
      // Update only own profile, cannot change role or email
      allow update: if isOwner(userId) && 
                       request.resource.data.role == resource.data.role &&
                       request.resource.data.email == resource.data.email;
      
      // Only admins can delete users
      allow delete: if hasRole('admin');
    }
    
    // Donor discovery - limited read for hospitals/bloodbanks
    match /donors_public/{donorId} {
      // Hospitals and blood banks can discover donors
      allow read: if hasAnyRole(['hospital', 'bloodbank', 'admin']);
      
      // Only the donor can update their public profile
      allow write: if isOwner(donorId);
    }

    // SOS Requests - role-based access
    match /sosRequests/{requestId} {
      // All authenticated users can read SOS requests
      allow read: if isAuthenticated();
      
      // Only hospitals and blood banks can create SOS requests
      allow create: if hasAnyRole(['hospital', 'bloodbank']) &&
                       request.resource.data.createdBy == request.auth.uid;
      
      // Creator or admin can update
      allow update: if resource.data.createdBy == request.auth.uid || 
                       hasRole('admin');
      
      // Creator or admin can delete
      allow delete: if resource.data.createdBy == request.auth.uid || 
                       hasRole('admin');
    }

    // Donations - role-based access
    match /donations/{donationId} {
      // Authenticated users can read donations
      allow read: if isAuthenticated();
      
      // Donors can create donations for themselves
      // Hospitals/bloodbanks can create donations
      allow create: if (hasRole('donor') && request.resource.data.donorId == request.auth.uid) ||
                       hasAnyRole(['hospital', 'bloodbank']);
      
      // Hospitals and admins can update donation status
      allow update: if hasAnyRole(['hospital', 'bloodbank', 'admin']);
      
      // Only admins can delete donations
      allow delete: if hasRole('admin');
    }

    // Audit log - write-only for all, read for admins
    match /audit_log/{logId} {
      allow create: if isAuthenticated();
      allow read: if hasRole('admin');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
